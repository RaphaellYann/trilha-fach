generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  password     String        
  isAdmin      Boolean        @default(false)
  isActive     Boolean        @default(true) 
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  taskProgress TaskProgress[]
  auditLogs    AuditLog[]
  evidences    TaskEvidence[] 
}

model TaskProgress {
  id        String   @id @default(cuid())
  taskId    String   @unique
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id])
}

model TaskEvidence {
  id        String   @id @default(cuid())
  taskId    String   // Ex: '1-1'
  fileUrl   String   // Link do arquivo
  fileName  String   // Nome original do arquivo
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  taskId    String   // ID da tarefa (ex: "1-0")
  action    String   // "CHECK" ou "UNCHECK"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}


model RoleResponsibility {
  id        String   @id @default(cuid())
  roleKey   String   // 'c' (Carmen), 'd' (Daiane) ou 'y' (Yuri)
  text      String   // O texto da responsabilidade
  order     Int      @default(0) // Ordem de exibição
  createdAt DateTime @default(now())
}